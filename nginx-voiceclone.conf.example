# VoiceClone reverse-proxy snippet for your external nginx box (HTTPS terminator).
# Serve at a domain ROOT (dedicated server_name / subdomain) — Gradio dislikes
# being mounted under a sub-path. If you must use a sub-path, set
# GRADIO_ROOT_PATH in run-vc.sh and tell me, and I'll adjust app.py.

server {
    listen 443 ssl;
    server_name voice.example.com;          # <-- your hostname

    ssl_certificate     /etc/letsencrypt/live/voice.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/voice.example.com/privkey.pem;

    client_max_body_size 1024m;             # large audio uploads

    location / {
        proxy_pass http://10.2.0.237:7865;  # kxkm-ai LAN IP (or 100.87.54.119 via Tailscale)
        proxy_http_version 1.1;

        # WebSocket upgrade — required by Gradio's event stream
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # training/conversion can stream for a long time
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}
